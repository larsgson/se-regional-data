{
  "name": "se-regional-data",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Scripture Earth regional data pipeline. Publishes per-country .pkf bundles + metadata as GitHub Release assets for consumption by se-regional-pwa.",
  "scripts": {
    "fetch": "python3 scripts/fetch_pkf.py --country MX --workers 8",
    "dedupe": "python3 scripts/dedupe_assets.py",
    "map:figures": "node scripts/map_figures.mjs",
    "map:media": "node scripts/map_media.mjs",
    "pack": "node scripts/pack_release.mjs",
    "diff": "node scripts/diff_manifest.mjs"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "proskomma-core": "^0.11.3"
  },
  "engines": {
    "node": ">=20"
  }
}
